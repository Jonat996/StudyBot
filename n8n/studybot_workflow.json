    {
      "parameters": {
        "jsCode": "const plan = items[0].json;\nconst schedule = plan.schedule || {};\nconst tasks = plan.tasks || [];\n\nconst diasNombres = {\n  monday: '📅 Lunes', tuesday: '📅 Martes', wednesday: '📅 Miércoles',\n  thursday: '📅 Jueves', friday: '📅 Viernes', saturday: '📅 Sábado', sunday: '📅 Domingo'\n};\nconst prioridadEmoji = { Maxima: '🔴', Alta: '🟠', Media: '🟡', Baja: '🟢' };\n\nlet mensaje = '📚 *Tu plan de estudio está listo*\\n\\n';\n\nfor (const tarea of tasks) {\n  const emoji = prioridadEmoji[tarea.priority] || '📖';\n  const cumplimiento = tarea.compliance_probability ? Math.round(tarea.compliance_probability * 100) : '--';\n  mensaje += `${emoji} *${tarea.subject}*\\n`;\n  mensaje += `   ⏱ Tiempo predicho: ${tarea.predicted_hours}h\\n`;\n  mensaje += `   📊 Probabilidad de cumplir: ${cumplimiento}%\\n\\n`;\n}\n\nmensaje += '🗓 *Cronograma semanal:*\\n\\n';\nfor (const [dia, sesiones] of Object.entries(schedule)) {\n  if (sesiones && sesiones.length > 0) {\n    mensaje += `${diasNombres[dia] || dia}:\\n`;\n    for (const s of sesiones) {\n      const e = prioridadEmoji[s.priority] || '•';\n      mensaje += `   ${e} ${s.subject} — ${s.hours}h\\n`;\n    }\n    mensaje += '\\n';\n  }\n}\n\nif (plan.max_day_load_pct) {\n  mensaje += `📈 _Carga máxima por día: ${plan.max_day_load_pct}%_\\n`;\n}\n\nreturn [{\n  json: {\n    mensaje: mensaje,\n    telegram_id: $('Extraer mensaje').item.json.telegram_id\n  }\n}];"
      },
      "type": "n8n-nodes-base.code",
      "typeVersion": 2,
      "position": [1792, 0],
