      "parameters": {
        "jsCode": "const result = items[0].json;\nconst telegramId = $('Extraer mensaje').item.json.telegram_id;\n\nif (result.error === 'calendar_not_connected') {\n  return [{\n    json: {\n      telegram_id: telegramId,\n      mensaje: '📅 _Tu plan está listo. Si quieres que lo agregue a tu Google Calendar, usa /conectar para vincularlo._'\n    }\n  }];\n}\n\nif (result.events_created && result.events_created > 0) {\n  return [{\n    json: {\n      telegram_id: telegramId,\n      mensaje: `✅ *¡${result.events_created} sesiones agendadas en tu Google Calendar!*\\n\\n_Revisa tu calendario para ver los horarios._`\n    }\n  }];\n}\n\nreturn [{\n  json: {\n    telegram_id: telegramId,\n    mensaje: ''\n  }\n}];"
