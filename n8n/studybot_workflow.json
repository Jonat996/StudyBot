    {
      "parameters": {
        "jsCode": "const data = items[0].json;\nconst tasks = data.tasks || [];\nconst telegramId = $('Extraer mensaje').item.json.telegram_id;\n\nif (tasks.length === 0) {\n  return [{\n    json: {\n      telegram_id: telegramId,\n      reply: '📋 *Tus tareas registradas*\\n\\n_No tienes tareas registradas aún. Cuéntame qué tienes que estudiar y te ayudo a organizarte._'\n    }\n  }];\n}\n\nconst prioridadEmoji = { Maxima: '🔴', Alta: '🟠', Media: '🟡', Baja: '🟢' };\nlet msg = '📋 *Tus tareas registradas:*\\n\\n';\n\nfor (const t of tasks.slice(0, 10)) {\n  const emoji = prioridadEmoji[t.priority] || '📖';\n  const estado = t.completed ? '✅' : '⏳';\n  msg += `${emoji} *${t.subject}* ${estado}\\n`;\n  msg += `   ⏱ Predicción: ${t.predicted_hours || t.estimated_hours}h | Dificultad: ${t.difficulty}/5\\n`;\n  if (t.due_date) msg += `   📅 Entrega: ${t.due_date}\\n`;\n  msg += '\\n';\n}\n\nif (tasks.length > 10) {\n  msg += `_... y ${tasks.length - 10} tareas más._\\n`;\n}\n\nreturn [{\n  json: {\n    telegram_id: telegramId,\n    reply: msg\n  }\n}];"
      },
