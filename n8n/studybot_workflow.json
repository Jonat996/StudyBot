      "parameters": {
        "jsCode": "const msg = items[0].json.message;\nconst telegramId = msg.from.id;\nconst nombre = msg.from.first_name || 'Estudiante';\nconst username = msg.from.username || '';\nconst texto = msg.text || '';\n\nlet tipoMensaje = 'tarea';\nif (texto === '/start') tipoMensaje = 'inicio';\nelse if (texto === '/conectar') tipoMensaje = 'conectar_calendar';\nelse if (texto === '/misfechas') tipoMensaje = 'ver_tareas';\nelse if (texto === '/ayuda') tipoMensaje = 'ayuda';\n\nreturn [{\n  json: {\n    telegram_id: telegramId,\n    nombre: nombre,\n    username: username,\n    texto: texto,\n    tipo_mensaje: tipoMensaje\n  }\n}];"
      },
