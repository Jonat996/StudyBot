      "parameters": {
        "jsCode": "const r = items[0].json;\nconst nombre = r.student_name || 'Estudiante';\nconst tareas = r.tasks || [];\n\nconst prioridadEmoji = { Maxima: '🔴', Alta: '🟠', Media: '🟡', Baja: '🟢' };\n\nlet msg = `🌅 *¡Buenos días, ${nombre}!*\\n\\n`;\nmsg += `📚 *Tu plan de hoy:*\\n\\n`;\n\nfor (const t of tareas) {\n  const emoji = prioridadEmoji[t.priority] || '📖';\n  msg += `${emoji} *${t.subject}* — ${t.hours}h\\n`;\n  if (t.tip) msg += `   _${t.tip}_\\n`;\n  msg += '\\n';\n}\n\nmsg += `💪 _¡Tú puedes! Escríbeme si necesitas ajustar algo._`;\n\nreturn [{\n  json: {\n    telegram_id: r.student_id,\n    mensaje: msg\n  }\n}];"
      },
